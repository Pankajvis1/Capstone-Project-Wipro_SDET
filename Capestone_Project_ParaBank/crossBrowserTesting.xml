<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="ParaBank Cross Browser Suite" parallel="tests" thread-count="2">

    <listeners>
        <listener class-name="listener.TestListener"/>
    </listeners>

    <!-- Chrome -->
    <test name="Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
        	<class name="test.ParaBankTest"/>
            <class name="test.NegativeTest"/>
        </classes>
    </test>

    <!-- Safari -->
    <test name="Safari Tests">
        <parameter name="browser" value="safari"/>
        <classes>
        	<class name="test.ParaBankTest"/>
            <class name="test.NegativeTest"/>
        </classes>
    </test>

</suite>